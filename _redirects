# Binaris — Clean URL Redirects
# Works with Netlify, Cloudflare Pages, and compatible static hosts

/terms      /terms/index.html      200
/privacy    /privacy/index.html    200

# Cobinar OAuth callback — must NOT be caught by the SPA fallback
/auth/callback/ /auth/callback/callback.html 200
/auth/callback  /auth/callback/callback.html 200

# SPA fallback — send all unmatched routes to index
/*          /index.html            200
